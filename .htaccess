RewriteEngine On

# Force the production host onto HTTPS, but leave localhost/dev hosts alone.
# Trust proxy-forwarded HTTPS headers used by shared hosting / reverse proxies.
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteCond %{HTTP:Front-End-Https} !on [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L,NE]

# Redirect explicit .php requests to the clean extensionless route.
# Preserve HTTPS when the request is already secure, including proxy headers
# commonly used on shared hosting.
RewriteCond %{REQUEST_METHOD} ^(?:GET|HEAD)$ [NC]
RewriteCond %{THE_REQUEST} \s/+([^\s?]+?)\.php(?:[?\s]|$) [NC]
RewriteCond %1 !(^|/)(robots|sitemap)$ [NC]
RewriteCond %{HTTPS} =on [OR]
RewriteCond %{HTTP:X-Forwarded-Proto} https [NC,OR]
RewriteCond %{HTTP:Front-End-Https} on [NC]
RewriteRule ^ https://%{HTTP_HOST}/%1 [R=301,L,NE]

RewriteCond %{REQUEST_METHOD} ^(?:GET|HEAD)$ [NC]
RewriteCond %{THE_REQUEST} \s/+([^\s?]+?)\.php(?:[?\s]|$) [NC]
RewriteCond %1 !(^|/)(robots|sitemap)$ [NC]
RewriteRule ^ /%1 [R=301,L,NE]

RewriteRule ^robots\.txt$ robots.php [NC,L]
RewriteRule ^sitemap\.xml$ sitemap.php [NC,L]
RewriteRule ^robot\.txt$ robots.txt [NC,R=301,L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.php [NC,L]
